{
  "name": "@ksairi-org/expo-image",
  "version": "0.1.1",
  "description": "Expo image wrapper \u2014 part of @ksairi-org/* libs",
  "main": "./index.ts",
  "types": "./index.ts",
  "files": [
    "*.ts",
    "*.tsx",
    "**/*.ts",
    "**/*.tsx",
    "**/*.jpg",
    "!**/*.test.*"
  ],
  "peerDependencies": {
    "expo-image": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}